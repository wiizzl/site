---
import Slide from "@/components/Slide.astro";
---

<Slide title="Blog">
  <a href="/blog" draggable="false" class="flex h-full cursor-pointer items-center overflow-hidden">
    <span id="blog-text" class="inline-flex items-baseline text-[600px] whitespace-nowrap">
      <span>Bl</span>
      <span class="bg-primary/60 mx-2.5 inline-block h-[0.6em] w-[0.6em] shrink-0 rounded-full"></span>
      <span>g :)</span>
    </span>
  </a>
</Slide>

<script>
  import { animate } from "motion";
  import { createResponsiveScroll } from "@/utils/scroll";

  function init() {
    const text = document.getElementById("blog-text");
    if (!text) {
      return;
    }

    createResponsiveScroll("gallery-container", () => {
      const xDistance = window.innerWidth < 768 ? -400 : -640;

      return animate(text, { x: [350, xDistance] }, { ease: "linear", delay: 0.1 });
    });
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
