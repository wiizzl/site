---
import Slide from "@/components/Slide.astro";
---

<Slide title="Blog">
  <a href="/blog" class="flex h-full cursor-pointer items-center overflow-hidden">
    <span id="blog-text" class="-mt-15 inline-block text-9xl whitespace-nowrap md:text-[400px]">Blog :)</span>
  </a>
</Slide>

<script>
  import { animate, scroll } from "motion";

  function init() {
    const text = document.getElementById("blog-text");
    const container = document.getElementById("gallery-container");

    if (!text || !container) {
      return;
    }

    const isMobile = window.matchMedia("(max-width: 767px)").matches;
    const xDistance = isMobile ? -250 : -500;

    scroll(
      animate(
        text,
        {
          x: [350, xDistance],
        },
        {
          ease: "linear",
          delay: 0.1,
        },
      ),
      {
        target: container,
        offset: ["start start", "end end"],
      },
    );
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
