---
import Slide from "@/components/Slide.astro";

import { CONSTS } from "@/consts";
---

<Slide title="Contact" className="relative flex flex-col justify-between p-16">
  <div class="z-10 flex w-full items-center justify-between">
    {
      CONSTS.links.slice(0, 2).map((link) => (
        <a href={link.url} target={link.blank ? "_blank" : "_self"} class="text-6xl font-medium">
          {link.name}
        </a>
      ))
    }
  </div>

  <div class="absolute inset-0 flex items-center justify-center">
    <button id="copy-email" data-email={CONSTS.mail} class="relative h-[1em] cursor-copy overflow-hidden text-6xl font-medium">
      <div id="text-wrapper" class="flex flex-col items-center [&>span]:block">
        <span>Email</span>
        <span>Copié</span>
      </div>
    </button>
  </div>

  <div class="z-10 flex w-full items-center justify-between">
    {
      CONSTS.links.slice(2, 4).map((link) => (
        <a href={link.url} target={link.blank ? "_blank" : "_self"} class="text-6xl font-medium">
          {link.name}
        </a>
      ))
    }
  </div>
</Slide>

<script>
  import { animate } from "motion";

  function initCopy() {
    const btn = document.getElementById("copy-email");
    const wrapper = document.getElementById("text-wrapper");

    if (!btn || !wrapper) {
      return;
    }

    const email = btn.getAttribute("data-email");
    let isAnimating = false;

    btn.addEventListener("click", () => {
      if (isAnimating || !email) {
        return;
      }

      isAnimating = true;
      navigator.clipboard.writeText(email);

      animate(wrapper, { y: ["0%", "-50%"] }, { duration: 0.6, ease: "circOut" });

      setTimeout(() => {
        animate(wrapper, { y: ["-50%", "0%"] }, { duration: 0.6, ease: "circOut" }).finished.then(() => {
          isAnimating = false;
        });
      }, 1200);
    });
  }

  document.addEventListener("DOMContentLoaded", initCopy);
</script>
