---
import Slide from "@/components/Slide.astro";
---

<Slide title="Projets">
  <a href="/projects" draggable="false" class="flex h-full cursor-pointer items-center overflow-hidden">
    <span id="project-text" class="inline-flex items-baseline text-[600px] whitespace-nowrap">
      <span>Pr</span>
      <span class="bg-primary/60 mx-2.5 inline-block h-[0.6em] w-[0.6em] shrink-0 rounded-full"></span>
      <span>jets</span>
    </span>
  </a>
</Slide>

<script>
  import { animate } from "motion";
  import { createResponsiveScroll } from "@/utils/scroll";

  function init() {
    const text = document.getElementById("project-text");
    if (!text) {
      return;
    }

    createResponsiveScroll("gallery-container", () => {
      const xDistance = window.innerWidth < 768 ? -700 : -1400;

      return animate(text, { x: [100, xDistance] }, { ease: "linear" });
    });
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
