---
import Slide from "@/components/Slide.astro";

import { CONSTS } from "@/consts";
---

<Slide title={CONSTS.title}>
  <div id="text-container" class="absolute top-8 bottom-12 left-8 z-10 space-y-2.5 text-5xl font-medium [&_span]:block [&>p]:overflow-hidden md:[&>p:nth-child(even)]:ml-8">
    <p><span>Étudiant en</span></p>
    <p><span>informatique,</span></p>
    <p><span>Développeur</span></p>
    <p><span>freelance,</span></p>
    <p><span>Vice-champion</span></p>
    <p><span>de France 2025</span></p>
  </div>

  <div id="circle" class="bg-primary/60 ml-auto aspect-square h-full rounded-full"></div>
</Slide>

<script>
  import { animate, stagger } from "motion";

  function init() {
    const container = document.getElementById("text-container");
    const circle = document.getElementById("circle");
    const lines = container?.querySelectorAll("span");

    if (!circle || !lines || lines.length === 0) {
      return;
    }

    const runIntro = () => {
      animate(circle, { scale: [0, 1] }, { duration: 0.8, ease: "circOut", delay: 0.4 });

      animate(
        lines,
        { y: ["105%", "0%"] },
        {
          delay: stagger(0.08, { startDelay: 0.2 }),
          duration: 0.6,
          ease: [0.16, 1, 0.3, 1],
        },
      );
    };

    runIntro();
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
