---
import Map from "@/components/Map.astro";
---

<section id="gallery-container" class="relative w-full">
  <div class="sticky top-0 h-svh overflow-hidden">
    <div class="absolute top-16 left-0 flex w-full items-center justify-center">
      <Map />
    </div>
    <div id="gallery-track" class="flex h-full items-center gap-x-3 px-[30.5vw] md:gap-x-6">
      <slot />
    </div>
  </div>
</section>

<script>
  import { scroll, animate } from "motion";
  import Lenis from "lenis";

  if (history.scrollRestoration) {
    history.scrollRestoration = "manual";
  }

  function init() {
    window.scrollTo(0, 0);

    const lenis = new Lenis();

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    const container = document.getElementById("gallery-container");
    const track = document.getElementById("gallery-track");
    const cards = document.querySelectorAll(".project-card");

    if (!container || !track || cards.length < 2) {
      return;
    }

    const runIntro = () => {
      animate(cards[0], { scale: [0, 1] }, { duration: 0.9, ease: "circOut" });
      animate(cards[1], { opacity: [0, 1] }, { duration: 0.6, delay: 0.8, ease: "easeOut" });
    };

    let scrollStop: (() => void) | undefined;

    const updateGallery = () => {
      if (scrollStop) scrollStop();

      const scrollAmount = track.scrollWidth - window.innerWidth;
      container.style.height = `${Math.ceil(scrollAmount + window.innerHeight)}px`;

      scrollStop = scroll(
        animate(
          track,
          {
            x: [0, -scrollAmount * 0.3, -scrollAmount],
            scale: [1.65, 1.55, 1.45, 1.15, 1, 1, 1, 1, 1, 1, 1],
          },
          { ease: "linear" },
        ),
        { target: container, offset: ["start start", "end end"] },
      );
    };

    let resizeTimeout: number;
    const resizeObserver = new ResizeObserver(() => {
      clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(updateGallery, 100);
    });

    resizeObserver.observe(container);

    updateGallery();
    runIntro();
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
