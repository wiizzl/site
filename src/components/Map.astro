<div class="relative h-5 w-fit">
  <div id="track" class="flex h-full items-center gap-x-2.5">
    {Array.from({ length: 18 }).map(() => <div class="bg-muted-foreground/40 h-full w-px shrink-0" />)}
  </div>
  <div id="indicator" class="border-muted-foreground bg-background absolute top-0 left-0 h-full w-8.5 border"></div>
</div>

<script>
  import { animate } from "motion";
  import { createResponsiveScroll } from "@/utils/scroll";

  function init() {
    const indicator = document.getElementById("indicator");
    const track = document.getElementById("track");

    if (!indicator || !track) {
      return;
    }

    createResponsiveScroll("gallery-container", () => {
      const travelDistance = Math.max(0, track.offsetWidth - indicator.offsetWidth);

      return animate(indicator, { x: [0, travelDistance] }, { ease: "linear" });
    });
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
