---
import BaseHead from "@/layouts/BaseHead.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <main class="mx-auto h-full w-full max-w-screen-2xl px-4 py-10 md:px-10 md:py-40 lg:px-52 xl:px-80">
      <slot />
    </main>
  </body>
</html>
